# PaperVerifier - LLM Provider API Keys
# Copy this file to .env and fill in your API keys.
# Keys can also be managed via the Settings page or `paperverifier config`.

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# Grok (xAI)
GROK_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Minimax
MINIMAX_API_KEY=

# Kimi (Moonshot)
KIMI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# External API keys (optional)
SEMANTIC_SCHOLAR_API_KEY=

# Authentication (REQUIRED for production)
PV_APP_PASSWORD=
# Set to "1" to allow running without a password (local dev only)
# PV_ALLOW_INSECURE_LOCAL=1

# Application settings
PAPERVERIFIER_MAX_CONCURRENT_AGENTS=9
PAPERVERIFIER_MAX_DOCUMENT_SIZE_MB=100
PAPERVERIFIER_LOG_LEVEL=INFO
PAPERVERIFIER_LOG_FORMAT=json
PAPERVERIFIER_PIPELINE_TIMEOUT=1800

# External API polite-pool emails (optional, higher rate limits)
PAPERVERIFIER_OPENALEX_EMAIL=
PAPERVERIFIER_CROSSREF_EMAIL=
